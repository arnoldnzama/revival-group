# ════════════════════════════════════════════════════════════════════════════════
# VIDEO INTERACTIONS — Configuration Environment Variables
# ════════════════════════════════════════════════════════════════════════════════
#
# USAGE: Copiez ce fichier en ".env.local" et configurez vos valeurs
# Chargez ces variables dans video_interactions.php avec:
#   $env = parse_ini_file('.env.local');
#   define('DB_HOST', $env['DB_HOST']);
#

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES
# ─────────────────────────────────────────────────────────────────────────────

# Serveur MySQL
DB_HOST=localhost
DB_PORT=3306
DB_CHARSET=utf8mb4

# Base de données
DB_NAME=revival
DB_NAME_TEST=revival_db_test

# Utilisateur
DB_USER=alliance
DB_PASS=@Yllan5991

# Pool connexions
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# Environnement
APP_ENV=production
APP_DEBUG=false
APP_VERSION=2.0.0

# Domaine autorisé (CORS)
APP_DOMAIN=https://revival-business.com
APP_ORIGIN=https://revival-business.com

# Timezone
APP_TIMEZONE=Africa/Kinshasa

# ─────────────────────────────────────────────────────────────────────────────
# SÉCURITÉ & RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────

# Rate limiting (likes par IP et période)
RATE_LIMIT_LIKES_PER_IP=10
RATE_LIMIT_MINUTES=5

# Taille maximum commentaire (caractères)
MAX_COMMENT_LENGTH=500
MAX_AUTHOR_LENGTH=100

# Authentification HTTPS (production)
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000

# Clé de chiffrement optionnelle (future utilisation)
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Répertoire des logs
LOG_DIR=./logs

# Niveau de log (debug, info, warning, error, critical)
LOG_LEVEL=info

# Retention logs (jours)
LOG_RETENTION_DAYS=90

# Logs lentes (ms)
LOG_SLOW_QUERIES_MS=100

# ─────────────────────────────────────────────────────────────────────────────
# CACHE & PERFORMANCE
# ─────────────────────────────────────────────────────────────────────────────

# Utiliser Redis pour le cache (optionnel)
CACHE_DRIVER=file
CACHE_TTL=3600

# Redis (si CACHE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Notifications optionnelles)
# ─────────────────────────────────────────────────────────────────────────────

# Notification commentaires approuvés
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_FROM=no-reply@revival-business.com
NOTIFY_EMAIL_TO=admin@revival-business.com

# SMTP
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# ─────────────────────────────────────────────────────────────────────────────
# MODÉRATION
# ─────────────────────────────────────────────────────────────────────────────

# Commentaires approuvés automatiquement ?
AUTO_APPROVE_COMMENTS=true

# Détection de spam activée ?
ENABLE_SPAM_DETECTION=false

# Score spam seuil (0-100)
SPAM_SCORE_THRESHOLD=75

# ─────────────────────────────────────────────────────────────────────────────
# INTÉGRATION YOUTUBE (Optionnel)
# ─────────────────────────────────────────────────────────────────────────────

# YouTube API Key
YOUTUBE_API_KEY=
YOUTUBE_SYNC_ENABLED=false
YOUTUBE_SYNC_INTERVAL=3600

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNE & INTÉGRATIONS
# ─────────────────────────────────────────────────────────────────────────────

# Webhook pour notifications externes
WEBHOOK_URL=
WEBHOOK_ENABLED=false

# Analytics externe (Mixpanel, Amplitude, etc.)
ANALYTICS_TOKEN=
ANALYTICS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# DÉVELOPPEMENT & DEBUG
# ─────────────────────────────────────────────────────────────────────────────

# Debug mode (affiche infos additionnelles)
DEBUG_MODE=false

# JSONP support (CORS alternative)
ENABLE_JSONP=false

# Request timeout (ms)
REQUEST_TIMEOUT=10000

# Afficher les erreurs SQL (développement seulement)
SHOW_SQL_ERRORS=false
